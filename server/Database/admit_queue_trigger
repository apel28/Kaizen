-- Processes the entire admit_queue whenever a new row is inserted.
-- Allocation logic:
-- - For each row in admit_queue (highest priority first), if a free bed exists in that department:
--   - pick one free bed (and lock it),
--   - mark it occupied,
--   - insert into admitted using patient/doctor from visits,
--   - delete the queue row.
--
-- Concurrency notes:
-- - Uses FOR UPDATE SKIP LOCKED on both queue rows and beds to avoid double-assigning under concurrent inserts.
-- - Trigger is FOR EACH STATEMENT (not per-row) so bulk inserts only process once.

CREATE OR REPLACE FUNCTION process_admit_queue()
RETURNS void AS $$
DECLARE
	q_row RECORD;
	b_row RECORD;
BEGIN
	LOOP
		-- Lock one queue row at a time (highest priority first).
		SELECT aq.admission_id, aq.department_id
		INTO q_row
		FROM admit_queue aq
		ORDER BY aq.priority DESC, aq."date" ASC, aq.admission_id ASC
		FOR UPDATE SKIP LOCKED
		LIMIT 1;

		IF NOT FOUND THEN
			EXIT;
		END IF;

		-- Find and lock one free bed in the department.
		SELECT b.bed_id, r.room_id, w.ward_id
		INTO b_row
		FROM bed b
		JOIN room r ON r.room_id = b.room_id
		JOIN ward w ON w.ward_id = r.ward_id
		WHERE w.department_id = q_row.department_id
		  AND b.occupied = 'n'
		ORDER BY b.bed_id ASC
		FOR UPDATE SKIP LOCKED
		LIMIT 1;

		-- If no bed is free for that department, unlock nothing else and move on.
		-- (We leave the queue row for later when beds free up.)
		IF NOT FOUND THEN
			-- Release the row lock by ending the iteration without modifying it.
			CONTINUE;
		END IF;

		-- Mark bed occupied.
		UPDATE bed
		SET occupied = 'y'
		WHERE bed_id = b_row.bed_id;

		-- Insert into admitted using patient/doctor from visits (matched by admission_id).
		INSERT INTO admitted (patient_id, doctor_id, department_id, ward_id, room_id, bed_id)
		SELECT v.patient_id,
			   v.doctor_id,
			   q_row.department_id,
			   b_row.ward_id,
			   b_row.room_id,
			   b_row.bed_id
		FROM visits v
		WHERE v.admission_id = q_row.admission_id;

		-- Remove from queue after successful admission.
		DELETE FROM admit_queue
		WHERE admission_id = q_row.admission_id;
	END LOOP;
END;
$$ LANGUAGE plpgsql;


CREATE OR REPLACE FUNCTION admit_queue_process_trigger()
RETURNS TRIGGER AS $$
BEGIN
	PERFORM process_admit_queue();
	RETURN NULL;
END;
$$ LANGUAGE plpgsql;


DROP TRIGGER IF EXISTS admit_queue_process_t ON admit_queue;
CREATE TRIGGER admit_queue_process_t
AFTER INSERT ON admit_queue
FOR EACH STATEMENT
EXECUTE FUNCTION admit_queue_process_trigger();

